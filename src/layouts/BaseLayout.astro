---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE, LOCALES, type Locale } from '../consts';

interface Props {
  title: string;
  description: string;
  locale: Locale;
}
const { title, description, locale } = Astro.props;
const canonical = new URL(Astro.url.pathname, SITE.domain).href;
const htmlLang = locale === 'zh-cn' ? 'zh-Hans' : locale;
---
<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {LOCALES.map((loc) => (
      <link rel="alternate" hreflang={loc === 'zh-cn' ? 'zh-Hans' : loc} href={`${SITE.domain}/${loc}/`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${SITE.domain}/en/`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {SITE.ga4Id && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${SITE.ga4Id}`}></script>
        <script define:vars={{ id: SITE.ga4Id }} is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', id);
        </script>
      </>
    )}
  </head>
  <body>
    <Header locale={locale} />
    <main class="wrap">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
