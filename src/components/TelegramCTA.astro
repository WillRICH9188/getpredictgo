---
import { SITE, type Locale } from '../consts';
import { t } from '../i18n/ui';
const { locale } = Astro.props as { locale: Locale };
---
<section class="cta">
  <h2>{t(locale,'cta.title')}</h2>
  <p>{t(locale,'cta.body')}</p>
  <a class="btn green" href={SITE.telegram} target="_blank" rel="noopener">{t(locale,'cta.button')}</a>
</section>
