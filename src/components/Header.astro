---
import { SITE, type Locale } from '../consts';
import { t } from '../i18n/ui';
import LangSwitcher from './LangSwitcher.astro';
const { locale } = Astro.props as { locale: Locale };
const base = `/${locale}`;
---
<header class="site">
  <div class="bar-top">
    <a class="brand" href={`${base}/`}>Predict <span>Go</span></a>
    <LangSwitcher current={locale} />
  </div>

  <nav class="main-scroll-container">
    <div class="main-scroll" id="nav-scroll">
    <a href={`${base}/basics/`}>{t(locale,'nav.basics')}</a>
    <a href={`${base}/how-to/`}>{t(locale,'nav.howto')}</a>
    <a href={`${base}/sports/`}>{t(locale,'nav.sports')}</a>
    <a href={`${base}/politics/`}>{t(locale,'nav.politics')}</a>
    <a href={`${base}/finance/`}>{t(locale,'nav.finance')}</a>
    <a href={`${base}/data/`}>{t(locale,'nav.data')}</a>
    <a href={`${base}/other/`}>{t(locale,'nav.other')}</a>
    </div>
  </nav>
</header>

<style>
  header.site {
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    background: rgba(15,18,22,.95);
    backdrop-filter: blur(10px);
    z-index: 10;
  }

  nav.main-scroll-container {
    width: 100%;
  }

  .bar-top {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px 20px;
    position: relative;
  }

  .bar-top .brand {
    position: absolute;
    left: 20px;
  }

  .bar-top > div:last-child {
    position: absolute;
    right: 20px;
  }

  .brand {
    font-weight: 800;
    font-size: 28px;
    color: var(--text);
    text-decoration: none;
    flex-shrink: 0;
  }

  .brand span {
    color: var(--accent);
  }

  .main-scroll {
    display: flex;
    gap: 2.5rem;
    padding: 0 20px;
    overflow-x: auto;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    width: 100%;
    justify-content: center;
    /* 隱藏滾動條 */
    scrollbar-width: none;
  }

  .main-scroll::-webkit-scrollbar {
    display: none;
  }

  .main-scroll a {
    padding: 12px 8px;
    white-space: nowrap;
    color: var(--muted);
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    transition: all 0.3s ease;
    border-bottom: 2px solid transparent;
  }

  .main-scroll a:hover {
    color: var(--text);
    border-bottom-color: var(--accent);
  }

  @media(max-width: 620px) {
    .bar-top {
      padding: 12px 12px;
    }

    .brand {
      font-size: 26px;
    }

    .main-scroll {
      gap: 1.5rem;
      padding: 12px;
      -webkit-overflow-scrolling: touch;
    }

    .main-scroll a {
      font-size: 14px;
      padding: 8px 0;
    }
  }
</style>

<script is:inline>
  // 平滑滾動支持
  const nav = document.getElementById('nav-scroll');
  if (nav) {
    let isDown = false;
    let startX;
    let scrollLeft;

    nav.addEventListener('mousedown', (e) => {
      isDown = true;
      startX = e.pageX - nav.offsetLeft;
      scrollLeft = nav.scrollLeft;
    });

    nav.addEventListener('mouseleave', () => {
      isDown = false;
    });

    nav.addEventListener('mouseup', () => {
      isDown = false;
    });

    nav.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - nav.offsetLeft;
      const walk = (x - startX) * 1;
      nav.scrollLeft = scrollLeft - walk;
    });
  }
</script>
