---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TelegramCTA from '../../../components/TelegramCTA.astro';
import { LOCALES, CATEGORIES, type Locale } from '../../../consts';
import { t } from '../../../i18n/ui';

export async function getStaticPaths() {
  const paths = [];
  for (const lang of LOCALES) for (const category of CATEGORIES) paths.push({ params: { lang, category } });
  return paths;
}

const lang = Astro.params.lang as Locale;
const category = Astro.params.category as string;
const list = await getCollection('articles', (e) => e.data.lang === lang && e.data.category === category);
list.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
function slugOf(id: string) { return id.split('/').slice(1).join('/'); }
const labelKey: Record<string,string> = { basics:'nav.basics','how-to':'nav.howto',sports:'nav.sports',politics:'nav.politics',finance:'nav.finance',data:'nav.data' };
const label = t(lang, labelKey[category] ?? 'nav.basics');
---
<BaseLayout title={`${label} — Predict Go`} description={label} locale={lang}>
  <h2 class="section">{label}</h2>
  {list.length === 0 && <p style="color:var(--muted)">—</p>}
  <div class="grid">
    {list.map((a) => (
      <a class="card" href={`/${lang}/${category}/${slugOf(a.id)}/`}>
        <h3>{a.data.title}</h3>
        <p>{a.data.description}</p>
      </a>
    ))}
  </div>
  <TelegramCTA locale={lang} />
</BaseLayout>
