---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TelegramCTA from '../../components/TelegramCTA.astro';
import { SITE, LOCALES, CATEGORIES, type Locale } from '../../consts';
import { t } from '../../i18n/ui';

export async function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
const all = await getCollection('articles', (e) => e.data.lang === lang);
all.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function slugOf(id: string) { return id.split('/').slice(1).join('/'); }
const catLabel: Record<string, string> = {
  basics: t(lang,'nav.basics'), 'how-to': t(lang,'nav.howto'),
  sports: t(lang,'nav.sports'), politics: t(lang,'nav.politics'),
  finance: t(lang,'nav.finance'), data: t(lang,'nav.data'),
};
---
<BaseLayout title={`Predict Go — ${t(lang,'hero.title')}`} description={t(lang,'hero.subtitle')} locale={lang}>
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content">
      <h1>{t(lang,'hero.title')}</h1>
      <p>{t(lang,'hero.subtitle')}</p>
      <a class="btn btn-primary" href={SITE.telegram} target="_blank" rel="noopener">{t(lang,'hero.cta')}</a>
    </div>
  </section>

  <!-- Latest Articles Section -->
  {all.length > 0 && (
    <section class="latest-section">
      <div class="section-header">
        <h2>{t(lang,'home.latest')}</h2>
      </div>
      
      <div class="articles-grid">
        {all.slice(0, 12).map((a) => (
          <article class="article-card">
            <a href={`/${lang}/${a.data.category}/${slugOf(a.id)}/`}>
              <div class="article-header">
                <span class="category-badge">{catLabel[a.data.category]}</span>
              </div>
              <h3>{a.data.title}</h3>
              <p class="description">{a.data.description}</p>
              <div class="article-footer">
                <span class="read-more">{t(lang,'readmore')} →</span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </section>
  )}

  <TelegramCTA locale={lang} />

  <style>
    .hero {
      padding: 4rem 2rem 5.5rem;
      text-align: center;
      background: linear-gradient(135deg, rgba(20,30,48,1) 0%, rgba(30,40,60,1) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 420px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .hero-content {
      max-width: 900px;
      margin: 0 auto;
    }

    .hero-content h1 {
      font-size: clamp(2.2rem, 8vw, 3.75rem);
      margin-bottom: 1.25rem;
      font-weight: 800;
      line-height: 1.15;
      letter-spacing: -0.02em;
    }

    .hero-content p {
      font-size: clamp(1.05rem, 3.5vw, 1.35rem);
      margin-bottom: 2.75rem;
      opacity: 0.88;
      line-height: 1.7;
      color: rgba(255,255,255,0.9);
    }

    .btn-primary {
      display: inline-block;
      padding: 1.2rem 3.5rem;
      background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
      color: white;
      border-radius: 0.625rem;
      text-decoration: none;
      transition: all 0.3s ease;
      font-weight: 700;
      font-size: 1rem;
      letter-spacing: 0.5px;
      box-shadow: 0 4px 15px rgba(37,99,235,0.3);
      border: none;
      cursor: pointer;
      min-width: 240px;
    }

    .btn-primary:hover {
      background: linear-gradient(135deg, #1d4ed8 0%, #1e40af 100%);
      transform: translateY(-3px);
      box-shadow: 0 8px 20px rgba(37,99,235,0.4);
    }

    .latest-section {
      padding: 5rem 2rem;
      max-width: 1400px;
      margin: 0 auto;
    }

    .section-header {
      margin-bottom: 3.5rem;
      text-align: center;
    }

    .section-header h2 {
      font-size: clamp(2rem, 5vw, 3rem);
      margin-bottom: 0.75rem;
      font-weight: 800;
      letter-spacing: -0.02em;
    }

    /* Articles Grid - Responsive with explicit breakpoints */
    .articles-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2.5rem;
      margin-bottom: 3rem;
    }

    .article-card {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 1rem;
      overflow: hidden;
      transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
      display: flex;
      flex-direction: column;
      min-height: 100%;
      backdrop-filter: blur(10px);
    }

    .article-card a {
      padding: 2.5rem;
      text-decoration: none;
      color: inherit;
      display: flex;
      flex-direction: column;
      height: 100%;
      gap: 1rem;
    }

    .article-card:hover {
      border-color: rgba(37,99,235,0.4);
      background: rgba(37,99,235,0.06);
      transform: translateY(-6px);
      box-shadow: 0 12px 32px rgba(37,99,235,0.15), 0 0 1px rgba(37,99,235,0.1);
    }

    .article-header {
      display: flex;
      align-items: center;
    }

    .category-badge {
      display: inline-flex;
      background: linear-gradient(135deg, rgba(37,99,235,0.15), rgba(59,130,246,0.1));
      color: #60a5fa;
      padding: 0.4rem 1rem;
      border-radius: 9999px;
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      border: 1px solid rgba(37,99,235,0.2);
      width: fit-content;
    }

    .article-card h3 {
      font-size: 1.25rem;
      margin: 0;
      line-height: 1.5;
      flex-grow: 0;
      font-weight: 700;
      letter-spacing: -0.01em;
    }

    .description {
      font-size: 0.975rem;
      opacity: 0.8;
      margin: 0;
      flex-grow: 1;
      line-height: 1.7;
    }

    .article-footer {
      padding-top: 1.5rem;
      margin-top: auto;
      display: flex;
      align-items: center;
    }

    .read-more {
      color: #60a5fa;
      font-weight: 700;
      transition: all 0.3s ease;
      font-size: 0.95rem;
      letter-spacing: 0.3px;
    }

    .article-card:hover .read-more {
      color: #93c5fd;
      transform: translateX(4px);
    }

    /* Tablet: 1024px and below */
    @media (max-width: 1024px) {
      .hero {
        padding: 3.5rem 2rem 4.5rem;
        min-height: 380px;
      }

      .hero-content h1 {
        margin-bottom: 1rem;
      }

      .hero-content p {
        margin-bottom: 2.25rem;
      }

      .articles-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 1.75rem;
      }

      .latest-section {
        padding: 4rem 2rem;
      }

      .article-card a {
        padding: 1.875rem;
      }
    }

    /* Mobile: 768px and below */
    @media (max-width: 768px) {
      .hero {
        padding: 3.5rem 1.5rem;
        min-height: 360px;
      }

      .hero-content h1 {
        font-size: clamp(1.8rem, 7vw, 2.5rem);
        margin-bottom: 0.875rem;
      }

      .hero-content p {
        font-size: clamp(1rem, 3vw, 1.15rem);
        margin-bottom: 2rem;
      }

      .btn-primary {
        padding: 1rem 2.25rem;
        font-size: 0.95rem;
        min-width: 200px;
      }

      .latest-section {
        padding: 3.5rem 1.5rem;
      }

      .section-header {
        margin-bottom: 2.5rem;
      }

      .section-header h2 {
        font-size: clamp(1.5rem, 4vw, 2rem);
      }

      .articles-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 1.75rem;
      }

      .article-card a {
        padding: 1.5rem;
        gap: 0.75rem;
      }

      .article-card h3 {
        font-size: 1.1rem;
      }

      .description {
        font-size: 0.9375rem;
      }
    }

    /* Small mobile: 640px and below */
    @media (max-width: 640px) {
      .hero {
        padding: 2.5rem 1.25rem;
        min-height: 340px;
      }

      .hero-content h1 {
        font-size: 1.65rem;
      }

      .hero-content p {
        font-size: 0.95rem;
        margin-bottom: 1.75rem;
      }

      .btn-primary {
        padding: 0.95rem 2rem;
        font-size: 0.9rem;
      }

      .latest-section {
        padding: 2.5rem 1.25rem;
      }

      .articles-grid {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }

      .article-card a {
        padding: 1.375rem;
      }

      .article-card h3 {
        font-size: 1.05rem;
      }

      .description {
        font-size: 0.9rem;
      }
    }

    /* Extra small: 375px and below */
    @media (max-width: 375px) {
      .hero {
        padding: 2rem 1rem;
        min-height: 320px;
      }

      .hero-content h1 {
        font-size: 1.5rem;
        margin-bottom: 0.75rem;
      }

      .hero-content p {
        font-size: 0.9rem;
        margin-bottom: 1.5rem;
      }

      .btn-primary {
        padding: 0.875rem 1.75rem;
        font-size: 0.85rem;
      }

      .article-card a {
        padding: 1.25rem;
      }
    }
  </style>
</BaseLayout>
